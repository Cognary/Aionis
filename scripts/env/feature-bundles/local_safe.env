# Safe local baseline.
# Use this when you want the repo to stay conservative and low-risk.

AIONIS_MODE=local
APP_ENV=dev
MEMORY_AUTH_MODE=off

MEMORY_RECALL_CLASS_AWARE_ENABLED=false
MEMORY_PLANNING_CONTEXT_OPTIMIZATION_PROFILE_DEFAULT=off
MEMORY_CONTEXT_ASSEMBLE_OPTIMIZATION_PROFILE_DEFAULT=off
MEMORY_RECALL_TEXT_CONTEXT_TOKEN_BUDGET_DEFAULT=0

SANDBOX_ENABLED=false
REPLAY_GUIDED_REPAIR_ALLOW_REQUEST_BUILTIN_LLM=false
REPLAY_LEARNING_PROJECTION_ENABLED=false
REPLAY_REPAIR_REVIEW_AUTO_PROMOTE_DEFAULT=false
MEMORY_SHADOW_DUAL_WRITE_ENABLED=false
MEMORY_SHADOW_DUAL_WRITE_STRICT=false

OPS_DANGEROUS_ACTIONS_ENABLED=false
