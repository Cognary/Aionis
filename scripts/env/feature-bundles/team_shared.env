# Shared team / staging bundle.
# Fill in placeholder values before use.

AIONIS_MODE=service
APP_ENV=prod
TRUST_PROXY=true
MEMORY_AUTH_MODE=api_key
MEMORY_API_KEYS_JSON={"replace-me":{"tenant_id":"default","agent_id":"agent_a","team_id":"team_default","role":"member"}}

CORS_ALLOW_ORIGINS=https://app.example.com
CORS_ADMIN_ALLOW_ORIGINS=https://ops.example.com

MEMORY_RECALL_CLASS_AWARE_ENABLED=false
MEMORY_PLANNING_CONTEXT_OPTIMIZATION_PROFILE_DEFAULT=balanced
MEMORY_CONTEXT_ASSEMBLE_OPTIMIZATION_PROFILE_DEFAULT=balanced
MEMORY_RECALL_TEXT_CONTEXT_TOKEN_BUDGET_DEFAULT=1200

SANDBOX_ENABLED=false
REPLAY_GUIDED_REPAIR_ALLOW_REQUEST_BUILTIN_LLM=false
REPLAY_LEARNING_PROJECTION_ENABLED=false
REPLAY_REPAIR_REVIEW_AUTO_PROMOTE_DEFAULT=false
MEMORY_SHADOW_DUAL_WRITE_ENABLED=false

OPS_BASIC_AUTH_ENABLED=true
OPS_BASIC_AUTH_USER=ops
OPS_BASIC_AUTH_PASS=change-me
OPS_DANGEROUS_ACTIONS_ENABLED=false
